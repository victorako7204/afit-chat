# ===========================================
# AFIT CHAT - RENDER DEPLOYMENT
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# ===========================================
# MONGODB (Required)
# ===========================================
# Get free cluster at: https://www.mongodb.com/atlas
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/afit-chat

# ===========================================
# JWT SECRET (Required)
# ===========================================
# Generate a secure random string: https://1password.com/password-generator/
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters

# ===========================================
# CLOUDINARY (Optional - for PDF uploads)
# ===========================================
# Get credentials at: https://cloudinary.com
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ===========================================
# SERVER CONFIG
# ===========================================
PORT=10000
NODE_ENV=production

# Client URL (for CORS) - Update after frontend deployment
# For local development: http://localhost:3000
# For Render frontend: https://your-frontend.onrender.com
CLIENT_URL=http://localhost:3000
